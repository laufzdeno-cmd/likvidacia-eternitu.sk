NEXT_PUBLIC_SITE_URL=https://likvidacia-eternitu.sk

# Databáza
# Produkcia na Verceli: PostgreSQL / Neon / Supabase / Vercel Postgres.
# Bez DATABASE_URL aplikácia používa iba lokálny vývojový súbor .data/local-db.json.
DATABASE_URL=

# Admin
AUTH_SECRET=
ADMIN_EMAIL=astana@astana.sk
ADMIN_PASSWORD_HASH=
# Iba lokálne, ak ešte nemáte hash:
ADMIN_PASSWORD=

# Ochrana formulára
ALLOWED_ORIGINS=https://likvidacia-eternitu.sk,http://localhost:3000,http://localhost:5173

# Emailové notifikácie
LEAD_TO_EMAIL=astana@astana.sk
MAIL_FROM=astana@astana.sk
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Bezpečné úložisko fotiek - S3 kompatibilné úložisko
# Ak nie je nastavené, lokálne sa súbory ukladajú do ./storage/lead-files.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
