{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "functions": {
    "app/api/admin/ponuka/[id]/pdf/route.ts": {
      "includeFiles": "node_modules/@sparticuz/chromium/bin/**"
    }
  },
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
